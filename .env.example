# .env.example — copy to .env and fill in your values
# NEVER commit .env to git!

DISCORD_TOKEN=your-bot-token-here

# Optional: set to your test server's guild ID for instant command sync during
# local development. Avoids the ~1-hour global propagation delay.
# Find it in Discord: right-click your server → Copy Server ID (Developer Mode on).
# DEV_GUILD_ID=your-guild-id-here

# Database connection (local Docker Postgres default shown).
# Omit to use the default: postgresql+asyncpg://bot:bot@localhost:5432/adventurer_sheet
# Railway injects this automatically when you add a Postgres plugin.
# DATABASE_URL=postgresql+asyncpg://bot:bot@localhost:5432/adventurer_sheet
